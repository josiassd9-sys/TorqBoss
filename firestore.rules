rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'torqboss@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'aiCredits', 'isProMember']) &&
             data.uid == request.auth.uid &&
             data.aiCredits is int && data.aiCredits >= 0 &&
             data.isProMember is bool &&
             (data.keys().size() <= 5); // Prevent shadow fields
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Prevent listing all users
      allow list: if isAdmin();

      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      incoming().aiCredits == 10 && // Free starter bonus
                      incoming().isProMember == false;

      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && (
                        isAdmin() || (
                          // Action: Consume Credits
                          (incoming().aiCredits < existing().aiCredits && 
                           incoming().diff(existing()).affectedKeys().hasOnly(['aiCredits', 'transactionHistory'])) ||
                          
                          // Action: Simulating Purchase (Allowed for Josias to test, in Prod would be Admin/Webhook only)
                          (incoming().aiCredits > existing().aiCredits && 
                           incoming().diff(existing()).affectedKeys().hasOnly(['aiCredits', 'transactionHistory'])) ||

                          // Action: Upgrade to PRO (Simulated)
                          (incoming().isProMember == true && existing().isProMember == false &&
                           incoming().diff(existing()).affectedKeys().hasOnly(['isProMember', 'transactionHistory']))
                        )
                      );
      
      allow delete: if isAdmin();
    }
  }
}
